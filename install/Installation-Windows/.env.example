# ============================================================
# MOM Generator - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is created automatically by setup.bat
# ============================================================

# Prevent Windows symlink errors with HuggingFace model downloads
HF_HUB_DISABLE_SYMLINKS=1
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Ollama server URL (local only - do not change)
OLLAMA_URL=http://127.0.0.1:11434
